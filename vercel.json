{
  "version": 2,
  "builds": [
    {
      "src": "frame-ai-landing/api/chat.js",
      "use": "@vercel/node"
    },
    {
      "src": "frame-ai-landing/package.json",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "npm run build",
        "outputDirectory": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/chat",
      "dest": "/frame-ai-landing/api/chat"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}